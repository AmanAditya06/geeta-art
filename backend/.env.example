# Database (Render PostgreSQL or Supabase)
DATABASE_URL="postgresql://user:password@host:5432/geeta_art"

# Auth — IMPORTANT: Generate real secrets with `openssl rand -base64 48`
# Never use placeholder values in production
JWT_SECRET="generate-a-real-random-secret-min-32-chars"
NEXTAUTH_SECRET="generate-a-real-random-secret-min-32-chars"
NEXTAUTH_URL="https://your-vercel-app.vercel.app"

# CORS (comma-separated allowed origins for backend deployment)
CORS_ORIGIN="https://your-vercel-app.vercel.app"

# Razorpay
RAZORPAY_KEY_ID="your_razorpay_key_id"
RAZORPAY_KEY_SECRET="your_razorpay_key_secret"

# Optional: Cloudinary (for production image uploads)
CLOUDINARY_CLOUD_NAME="your_cloud_name"
CLOUDINARY_API_KEY="your_cloudinary_api_key"
CLOUDINARY_API_SECRET="your_cloudinary_api_secret"

# Server
PORT=10000
