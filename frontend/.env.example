# Supabase PostgreSQL Database URL
DATABASE_URL="postgresql://postgres:password@db.xxxxxx.supabase.co:5432/postgres"
# URL-encode special characters in password (@ -> %40, # -> %23, etc.)

# Auth — IMPORTANT: Generate real secrets with `openssl rand -base64 48`
# Never use placeholder values in production
JWT_SECRET="generate-a-real-random-secret-min-32-chars"
NEXTAUTH_SECRET="generate-a-real-random-secret-min-32-chars"
NEXTAUTH_URL="https://your-vercel-app.vercel.app"

# Razorpay
NEXT_PUBLIC_RAZORPAY_KEY_ID="your_razorpay_key_id"
RAZORPAY_KEY_ID="your_razorpay_key_id"
RAZORPAY_KEY_SECRET="your_razorpay_key_secret"

# API URL (for pages that call external backend; set to "/api" if using Next.js API routes only)
NEXT_PUBLIC_API_URL="/api"
